{
  "realm": "cancer-registry",
  "enabled": true,
  "displayName": "Cancer Registry",
  "roles": {
    "realm": [
      { "name": "registry_admin" },
      { "name": "registrar" },
      { "name": "clinician" },
      { "name": "auditor" },
      { "name": "analyst" }
    ]
  },
  "clients": [
